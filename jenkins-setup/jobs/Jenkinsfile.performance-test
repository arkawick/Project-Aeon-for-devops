/**
 * Aeon Demo — Performance Test Pipeline
 * Runs k6 load tests against staging. Fails when p95 latency
 * exceeds the 500ms SLA threshold after a recent DB schema change.
 */

def aeon_notify(String status, String errorSummary = '', String logs = '') {
    withCredentials([string(credentialsId: 'AEON_URL', variable: 'AEON')]) {
        def safeSummary = errorSummary.replace('"', '\\"').replace('\n', '\\n')
        def safeLogs    = logs.take(4000).replace('"', '\\"').replace('\n', '\\n')
        def payload = """{
            "source": "jenkins", "name": "${env.JOB_NAME}", "status": "${status}",
            "repo": "acme/backend-api", "branch": "${env.GIT_BRANCH ?: 'main'}",
            "build_number": ${env.BUILD_NUMBER}, "url": "${env.BUILD_URL}",
            "error_summary": "${safeSummary}", "logs": "${safeLogs}"
        }"""
        try {
            httpRequest(url: "${AEON}/api/pipelines/ingest", httpMode: 'POST',
                contentType: 'APPLICATION_JSON', requestBody: payload,
                timeout: 10, validResponseCodes: '100:299')
        } catch (Exception e) { echo "⚠️  Aeon notification failed: ${e.message}" }
    }
}

pipeline {
    agent any
    options { timestamps(); timeout(time: 30, unit: 'MINUTES'); buildDiscarder(logRotator(numToKeepStr: '10')) }

    environment {
        TARGET_URL   = 'https://staging.acme.internal'
        VUS          = '50'
        DURATION     = '5m'
        P95_THRESHOLD = '500'
    }

    stages {
        stage('Checkout') { steps { echo "📦 Checking out performance test scripts" } }
        stage('Warm-up') {
            steps {
                echo "🔥 Warming up staging environment (10 VUs, 30s)..."
                echo "✓ All endpoints responding — avg 89ms"
