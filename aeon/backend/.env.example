# --- LLM provider chain: Azure OpenAI (primary) -> Anthropic -> mock ---
# If AZURE_OPENAI_* are set, they are used first. AZURE_OPENAI_ENDPOINT is the
# FULL chat-completions URL incl. deployment path and api-version.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GITHUB_ORG=
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_TOKEN=
JENKINS_DEFAULT_JOB=
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
DATABASE_URL=postgresql://aeon:aeon@localhost:5432/aeon
REDIS_URL=redis://localhost:6379
CHROMA_HOST=localhost
CHROMA_PORT=8001
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=aeon_neo4j
# Odysseus extended workspace (optional — https://github.com/pewdiepie-archdaemon/odysseus)
# Use host.docker.internal so Aeon's Docker backend can reach Odysseus on the host
ODYSSEUS_URL=http://host.docker.internal:7000
